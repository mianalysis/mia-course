<?xml version="1.0" encoding="UTF-8"?><ROOT MIA_VERSION="1.7.26"><MODULES><MODULE CLASSNAME="io.github.mianalysis.mia.module.core.InputControl" DISABLEABLE="false" ENABLED="true" ID="1034442125" NAME="Input control" NICKNAME="Input control" NOTES="Standard file selection module, which allows for selection of the input filepath and extension.  The extension filter is only applied when a folder is selected." SHOW_BASIC_TITLE="true" SHOW_OUTPUT="false" VERSION="1.0.0"><PARAMETERS><PARAMETER NAME="No load message" NICKNAME="No load message" VALUE="&quot;Input control&quot; only specifies the path to the root image; no image is loaded into the workspace at this point.  To load images, add one or more &quot;Load Image&quot; modules." VISIBLE="false"/><PARAMETER NAME="Input path" NICKNAME="Input path" SHOW_TEXT="false" VALUE="/Users/sc13967/Documents/Programming/Java/mia-examples/Ex4_ManualSegmentation/Orientia_tsutsugamushi.tif" VISIBLE="true"/><PARAMETER NAME="Series mode" NICKNAME="Series mode" SHOW_TEXT="false" VALUE="All series" VISIBLE="false"/><PARAMETER NAME="Series list" NICKNAME="Series list" VALUE="1" VISIBLE="false"/><PARAMETER NAME="Only load first file per folder" NICKNAME="Only load first file per folder" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAMETER NAME="Only load first matching group" NICKNAME="Only load first matching group" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAMETER NAME="Pattern" NICKNAME="Pattern" VALUE="" VISIBLE="false"/><PARAMETER NAME="Spatial unit" NICKNAME="Spatial unit" SHOW_TEXT="false" VALUE="Micrometres" VISIBLE="false"/><PARAMETER NAME="Temporal unit" NICKNAME="Temporal unit" SHOW_TEXT="false" VALUE="Milliseconds" VISIBLE="false"/><PARAMETER NAME="Add filter" NICKNAME="Add filter" VALUE="" VISIBLE="false"><COLLECTION><PARAMS><PARAM NAME="Filter source" NICKNAME="Filter source" SHOW_TEXT="false" VALUE="Extension" VISIBLE="false"/><PARAM NAME="Filter value" NICKNAME="Extension" VALUE="tif" VISIBLE="true"/><PARAM