PARAMETER NAME="Metadata item for summary" NICKNAME="Metadata item for summary" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAMETER NAME="Show object counts" NICKNAME="Show object counts" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/><PARAMETER NAME="Export individual objects" NICKNAME="Export individual objects" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/></PARAMETERS><IMAGE_MEASUREMENTS/><OBJECT_MEASUREMENTS/><METADATA/></MODULE></MODULES><MODULES><MODULE CLASSNAME="io.github.mianalysis.mia.module.system.GUISeparator" DISABLEABLE="false" ENABLED="true" ID="289512958" NAME="GUI separator" NICKNAME="File loading" NOTES="" SHOW_BASIC_TITLE="true" SHOW_OUTPUT="false" VERSION="1.0.0"><PARAMETERS><PARAMETER NAME="Show in processing view" NICKNAME="Show in processing view" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/><PARAMETER NAME="Expanded in processing view" NICKNAME="Expanded in processing view" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/><PARAMETER NAME="Expanded in editing view" NICKNAME="Expanded in editing view" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/></PARAMETERS><IMAGE_MEASUREMENTS/><OBJECT_MEASUREMENTS/><METADATA/></MODULE><MODULE CLASSNAME="io.github.mianalysis.mia.module.inputoutput.ImageLoader" DISABLEABLE="false" ENABLED="true" ID="1505203727" NAME="Load image" NICKNAME="Load image" NOTES="This is the standard image loading module.  This image is loaded into the workspace as &quot;Image&quot;." SHOW_BASIC_TITLE="true" SHOW_OUTPUT="false" VERSION="1.0.0"><PARAMETERS><PARAMETER NAME="Output image" NICKNAME="Output image" VALUE="Image" VISIBLE="false"/><PARAMETER NAME="Import mode" NICKNAME="Import mode" SHOW_TEXT="false" VALUE="Current file" VISIBLE="false"/><PARAMETER NAME="Reader" NICKNAME="Reader" SHOW_TEXT="false" VALUE="Bio-Formats" VISIBLE="false"/><PARAMETER NAME="Sequence root name" NICKNAME="Sequence root name" VALUE="" VISIBLE="false"/><PARAMETER NAME="Name format" NICKNAME="Name format" SHOW_TEXT="false" VALUE="Generic (from metadata)" VISIBLE="false"/><PARAMETER NAME="Comment" NICKNAME="Comment" VALUE="" VISIBLE="false"/><PARAMETER NAME="Extension" NICKNAME="Extension" VALUE="" VISIBLE="false"/><PARAMETER NAME="Generic format" NICKNAME="Generic format" VALUE="" VISIBLE="false"/><PARAMETER NAME="Available metadata fields" NICKNAME="Available metadata fields" VALUE="" VISIBLE="false"/><PARAMETER NAME="Include series number" NICKNAME="Include series number" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/><PARAMETER NAME="File path" NICKNAME="File path" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAMETER NAME="Series mode" NICKNAME="Series mode" SHOW_TEXT="false" VALUE="Current series" VISIBLE="false"/><PARAMETER NAME="Series number" NICKNAME="Series number" VALUE="1" VISIBLE="false"/><PARAMETER NAME="Channels" NICKNAME="Channels" VALUE="1-end" VISIBLE="false"/><PARAMETER NAME="Slices" NICKNAME="Slices" VALUE="1-end" VISIBLE="false"/><PARAMETER NAME="Frames" NICKNAME="Frames" VALUE="1-end" VISIBLE="false"/><PARAMETER NAME="Channel" NICKNAME="Channel" VALUE="1" VISIBLE="false"/><PARAMETER NAME="Crop mode" NICKNAME="Crop mode" SHOW_TEXT="false" VALUE="None" VISIBLE="false"/><PARAMETER NAME="Reference image" NICKNAME="Reference image" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAMETER NAME="Left coordinate" NICKNAME="Left coordinate" VALUE="0" VISIBLE="false"/><PARAMETER NAME="Top coordinate" NICKNAME="Top coordinate" VALUE="0" VISIBLE="false"/><PARAMETER NAME="Width" NICKNAME="Width" VALUE="512" VISIBLE="false"/><PARAMETER NAME="Height" NICKNAME="Height" VALUE="512" VISIBLE="false"/><PARAMETER NAME="Objects for limits" NICKNAME="Objects for limits" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAMETER NAME="Scale mode" NICKNAME="Scale mode" SHOW_TEXT="false" VALUE="No scaling" VISIBLE="false"/><PARAMETER NAME="X scale factor" NICKNAME="X scale factor" VALUE="1.0" VISIBLE="false"/><PARAMETER NAME="Y scale factor" NICKNAME="Y scale factor" VALUE="1.0" VISIBLE="false"/><PARAMETER NAME="Dimension mismatch mode" NICKNAME="Dimension mismatch mode" SHOW_TEXT="false" VALUE="Disallow (fail upon mismatch)" VISIBLE="false"/><PARAMETER NAME="Pad intensity mode" NICKNAME="Pad intensity mode" SHOW_TEXT="false" VALUE="Black (0)" VISIBLE="false"/><PARAMETER NAME="Set manual spatial calibration" NICKNAME="Set manual spatial calibration" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAMETER NAME="XY calibration (dist/px)" NICKNAME="XY calibration (dist/px)" VALUE="1.0" VISIBLE="false"/><PARAMETER NAME="Z calibration (dist/px)" NICKNAME="Z calibration (dist/px)" VALUE="1.0" VISIBLE="false"/><PARAMETER NAME="Set manual temporal calibration" NICKNAME="Set manual temporal calibration" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAMETER NAME="Frame interval (time/frame)" NICKNAME="Frame interval (time/frame)" VALUE="1.0" VISIBLE="false"/><PARAMETER NAME="Force bit depth" NICKNAME="Force bit depth" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAMETER NAME="Output bit depth" NICKNAME="Output bit depth" SHOW_TEXT="false" VALUE="8" VISIBLE="false"/><PARAMETER NAME="Minimum input intensity" NICKNAME="Minimum input intensity" VALUE="0.0" VISIBLE="false"/><PARAMETER NAME="Maximum input intensity" NICKNAME="Maximum input intensity" VALUE="1.0" VISIBLE="false"/></PARAMETERS><IMAGE_MEASUREMENTS/><OBJECT_MEASUREMENTS/><METADATA/></MODULE><MODULE CLASSNAME="io.github.mianalysis.mia.module.system.GUISeparator" DISABLEABLE="false" ENABLED="true" ID="1747073700" NAME="GUI separator" NICKNAME="Object selection" NOTES="" SHOW_BASIC_TITLE="true" SHOW_OUTPUT="false" VERSION="1.0.0"><PARAMETERS><PARAMETER NAME="Show in processing view" NICKNAME="Show in processing view" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/><PARAMETER NAME="Expanded in processing view" NICKNAME="Expanded in processing view" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/><PARAMETER NAME="Expanded in editing view" NICKNAME="Expanded in editing view" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/></PARAMETERS><IMAGE_MEASUREMENTS/><OBJECT_MEASUREMENTS/><METADATA/></MODULE><MODULE CLASSNAME="io.github.mianalysis.mia.module.inputoutput.LoadObjectsFromROIs" DISABLEABLE="false" ENABLED="true" ID="1508306126" NAME="Load objects from ROIs" NICKNAME="Load objects from ROIs" NOTES="When this workflow runs, it saves the selected bacteria as ImageJ regions of interest (ROIs) to a file starting with the same name as the input image file and ending with &quot;_bacteria.zip&quot;.  These ROIs can be loaded back into the workflow on subsequent runs to allow for editing.&#10;&#10;If the ROI file exists in the same folder as the input image file, this module will load the ROIs as the object set &quot;TempBacteria&quot;.&#10;&#10;The ROI file doesn't contain any information on the spatial limits or calibration of the object collection, so we provide this with the reference image,&#10;&#10;The path to the ROI file is dynamically created by injecting metadata values into the &quot;Generic file path&quot; parameter when the module runs.  Here, &quot;Me{Filepath}Me{Filename}&quot; will be replaced by the full path to the image, albeit without the &quot;.tif&quot; file extension.  The second half of the parameter adds on the &quot;_bacteria.zip&quot; part of the ROI filename." SHOW_BASIC_TITLE="true" SHOW_OUTPUT="false" VERSION="1.0.0"><PARAMETERS><PARAMETER NAME="Output objects" NICKNAME="Output objects" VALUE="TempBacteria" VISIBLE="false"/><PARAMETER NAME="Assign tracks" NICKNAME="Assign tracks" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAMETER NAME="Output track objects" NICKNAME="Output track objects" VALUE="" VISIBLE="false"/><PARAMETER NAME="Assign object class" NICKNAME="Assign object class" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAMETER NAME="Reference image" NICKNAME="Reference image" SHOW_TEXT="false" VALUE="Image" VISIBLE="false"/><PARAMETER NAME="File path mode" NICKNAME="File path mode" SHOW_TEXT="false" VALUE="Generic path" VISIBLE="false"/><PARAMETER NAME="Generic file path" NICKNAME="Generic file path" VALUE="Me{Filepath}Me{Filename}_bacteria.zip" VISIBLE="false"/><PARAMETER NAME="Available metadata fields" NICKNAME="Available metadata fields" VALUE="The following metadata values are available to use for generation of a filename string.  Each metadata reference should include the &quot;M{&quot; and &quot;}&quot;:&#13;&#10;&#13;&#10;M{Extension}, M{File}, M{Filename}, M{Filepath}, M{Series name}, M{Series number}&#13;&#10;&#13;&#10;Wildcard character &quot;*&quot; is also available to match variable content (first matching instance will be loaded)." VISIBLE="false"/><PARAMETER NAME="Specific file path" NICKNAME="Specific file path" SHOW_TEXT="false" VALUE="" VISIBLE="false"/></PARAMETERS><IMAGE_MEASUREMENTS/><OBJECT_MEASUREMENTS/><METADATA/></MODULE><MODULE CLASSNAME="io.github.mianalysis.mia.module.objects.detect.ManuallyIdentifyObjects" DISABLEABLE="false" ENABLED="true" ID="424459718" NAME="Manually identify objects" NICKNAME="Manually identify objects" NOTES="This module is used to manually select objects from an image.  &#10;&#10;In its simplest form, we provide the input image on which we wish to draw the objects and an output name for the created objects.  However, here, we potentially have an existing object set loaded in by the &quot;Load objects from ROIs&quot; module.  We can include these with the &quot;Add existing objects&quot; parameter.  &#10;&#10;When this module runs, it displays the selected image and a control panel for managing the selected objects.  To add an object, draw round the object on the image with the standard ImageJ ROI tools, then click &quot;Add as new object&quot;, which will add it to the object list in the control panel.  It's possible to select the objects from this list, which will highlight them in the image.  To delete an object, select it in the list, then click &quot;Remove object(s)&quot;.  Similarly, multiple objects can be deleted at once by selecting them in the list.&#10;&#10;If annotating objects across multiple timepoints or slices, selected regions can be added to an existing object by clicking &quot;Add to existing object&quot;.  When doing this, the number to the right of this button must match the target object.&#10;&#10;To make annotating objects faster, the &quot;When region drawn&quot; setting in the control panel can be set to automatically add the region as a new object or to an existing object.&#10;&#10;When object selection is complete, click &quot;Finish adding objects&quot;, which will automatically close the image and control panel." SHOW_BASIC_TITLE="true" SHOW_OUTPUT="false" VERSION="1.1.0"><PARAMETERS><PARAMETER NAME="Save location" NICKNAME="Save location" SHOW_TEXT="false" VALUE="Save with input file" VISIBLE="false"/><PARAMETER NAME="Mirrored directory root" NICKNAME="Mirrored directory root" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAMETER NAME="File path" NICKNAME="File path" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAMETER NAME="File name (generic)" NICKNAME="File name (generic)" VALUE="" VISIBLE="false"/><PARAMETER NAME="Save name mode" NICKNAME="Save name mode" SHOW_TEXT="false" VALUE="Match input file name" VISIBLE="false"/><PARAMETER NAME="File name" NICKNAME="File name" VALUE="" VISIBLE="false"/><PARAMETER NAME="Available metadata fields" NICKNAME="Available metadata fields" VALUE="" VISIBLE="false"/><PARAMETER NAME="Append series mode" NICKNAME="Append series mode" SHOW_TEXT="false" VALUE="Series number" VISIBLE="false"/><PARAMETER NAME="Append date/time mode" NICKNAME="Append date/time mode" SHOW_TEXT="false" VALUE="Never" VISIBLE="false"/><PARAMETER NAME="Add filename suffix" NICKNAME="Add filename suffix" VALUE="" VISIBLE="false"/><PARAMETER NAME="Input image" NICKNAME="Input image" SHOW_TEXT="false" VALUE="Image" VISIBLE="false"/><PARAMETER NAME="Add existing objects" NICKNAME="Add existing objects" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/><PARAMETER NAME="Input objects" NICKNAME="Input objects" SHOW_TEXT="false" VALUE="TempBacteria" VISIBLE="false"/><PARAMETER NAME="Existing object type" NICKNAME="Existing object type" SHOW_TEXT="false" VALUE="Regions" VISIBLE="false"/><PARAMETER NAME="Allow missing objects" NICKNAME="Allow missing objects" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAMETER NAME="Apply existing class" NICKNAME="Apply existing class" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAMETER NAME="Metadata item for class" NICKNAME="Metadata item for class" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAMETER NAME="Output objects" NICKNAME="Output objects" VALUE="Bacteria" VISIBLE="false"/><PARAMETER NAME="Volume type" NICKNAME="Volume type" SHOW_TEXT="false" VALUE="Quadtree" VISIBLE="false"/><PARAMETER NAME="Spatial interpolation" NICKNAME="Spatial interpolation" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAMETER NAME="Output tracks" NICKNAME="Output tracks" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAMETER NAME="Output track objects" NICKNAME="Output track objects" VALUE="" VISIBLE="false"/><PARAMETER NAME="Temporal interpolation" NICKNAME="Temporal interpolation" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAMETER NAME="Assign classes" NICKNAME="Assign classes" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAMETER NAME="Classes source" NICKNAME="Classes source" SHOW_TEXT="false" VALUE="Fixed list" VISIBLE="false"/><PARAMETER NAME="Class file" NICKNAME="Class file" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAMETER NAME="Allow additions" NICKNAME="Allow additions" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAMETER NAME="Class list (comma-separated)" NICKNAME="Class list (comma-separated)" VALUE="" VISIBLE="false"/><PARAMETER NAME="Instruction text" NICKNAME="Instruction text" VALUE="Draw round an object, then select one of the following&#10;(or click &quot;Finish adding objects&quot; at any time).&#10;Different timepoints must be added as new objects." VISIBLE="false"/><PARAMETER NAME="Default selector type" NICKNAME="Default selector type" SHOW_TEXT="false" VALUE="Freehand region" VISIBLE="false"/><PARAMETER NAME="Point mode (point-type ROIs only)" NICKNAME="Point mode (point-type ROIs only)" SHOW_TEXT="false" VALUE="Individual objects" VISIBLE="false"/><PARAMETER NAME="Message on image" NICKNAME="Message on image" VALUE="Draw objects on this image" VISIBLE="false"/></PARAMETERS><IMAGE_MEASUREMENTS/><OBJECT_MEASUREMENTS/><METADATA/></MODULE><MODULE CLASSNAME="io.github.mianalysis.mia.module.inputoutput.SaveObjectsAsROIs" DISABLEABLE="false" ENABLED="true" ID="1153871469" NAME="Save objects as ROIs" NICKNAME="Save objects as ROIs" NOTES="Saving the selected &quot;Bacteria&quot; objects to an ImageJ region of interest (ROI) file.  This is a zipped archive containing ImageJ .roi files.  This archive can be dragged directly into ImageJ to load the ROIs to the standard ROi Manager.&#10;&#10;" SHOW_BASIC_TITLE="true" SHOW_OUTPUT="false" VERSION="1.0.0"><PARAMETERS><PARAMETER NAME="Save location" NICKNAME="Save location" SHOW_TEXT="false" VALUE="Save with input file" VISIBLE="false"/><PARAMETER NAME="Mirrored directory root" NICKNAME="Mirrored directory root" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAMETER NAME="File path" NICKNAME="File path" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAMETER NAME="File name (generic)" NICKNAME="File name (generic)" VALUE="" VISIBLE="false"/><PARAMETER NAME="Save name mode" NICKNAME="Save name mode" SHOW_TEXT="false" VALUE="Match input file name" VISIBLE="false"/><PARAMETER NAME="File name" NICKNAME="File name" VALUE="" VISIBLE="false"/><PARAMETER NAME="Available metadata fields" NICKNAME="Available metadata fields" VALUE="" VISIBLE="false"/><PARAMETER NAME="Append series mode" NICKNAME="Append series mode" SHOW_TEXT="false" VALUE="None" VISIBLE="false"/><PARAMETER NAME="Append date/time mode" NICKNAME="Append date/time mode" SHOW_TEXT="false" VALUE="Never" VISI